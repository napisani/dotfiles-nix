{
  "mcpServers": {
    "linear": {
      "lifecycle": "lazy",
      "url": "https://mcp.linear.app/mcp"
    },
    "figma": {
      "auth": "oauth",
      "lifecycle": "lazy",
      "oauth": {
        "clientName": "Codex",
        "clientUri": "https://github.com/openai/codex",
        "scope": "mcp:connect"
      },
      "url": "https://mcp.figma.com/mcp"
    },
    "agentmemory": {
      "command": "/Users/nick/.local/bin/agentmemory-mcp",
      "env": {
        "AGENTMEMORY_URL": "http://localhost:3111"
      },
      "lifecycle": "lazy"
    }
  }
}
